# ── Server ──
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1

# ── Database (PostgreSQL + PostGIS) ──
DATABASE_URL="postgresql://lvg_dev:lvg_dev_password@localhost:5433/laviagiusta?schema=public"

# ── Redis (BullMQ) ──
REDIS_URL="redis://localhost:6379"

# ── JWT ──
JWT_SECRET="change-me-in-production-use-a-long-random-string"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="change-me-too-different-from-above"
JWT_REFRESH_EXPIRES_IN="7d"

# ── Twilio (SMS & Chiamate Emergenza) ──
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ── Firebase (Push Notifications) ──
FIREBASE_SERVICE_ACCOUNT_PATH="./firebase-service-account.json"

# ── Watchdog Defaults ──
WATCHDOG_DEFAULT_TOLERANCE_PCT=40
WATCHDOG_ALERT_RESPONSE_TIMEOUT_SEC=180
WATCHDOG_OFFLINE_TIMEOUT_MIN=30
WATCHDOG_LOCATION_INTERVAL_SEC=30

# ── Emergency Numbers ──
EMERGENCY_SMS_NUMBERS=118,+39XXXXXXXXXX
EMERGENCY_CALL_NUMBER=+39XXXXXXXXXX

# ── Mapbox ──
MAPBOX_ACCESS_TOKEN=
